<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarPlates.Mobile.Controls.ScanOverlay">

    <Grid>
        <!-- Dark overlay with transparent center -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Top overlay -->
        <BoxView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                 BackgroundColor="Black" Opacity="0.6"/>

        <!-- Left overlay -->
        <BoxView Grid.Row="1" Grid.Column="0" 
                 BackgroundColor="Black" Opacity="0.6"/>

        <!-- Right overlay -->
        <BoxView Grid.Row="1" Grid.Column="2" 
                 BackgroundColor="Black" Opacity="0.6"/>

        <!-- Bottom overlay -->
        <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
                 BackgroundColor="Black" Opacity="0.6"/>

        <!-- Scan frame -->
        <Border Grid.Row="1" Grid.Column="1"
               BackgroundColor="Transparent"
               Stroke="{StaticResource Primary}"
               StrokeShape="RoundRectangle 8"
               Padding="0">
            <!-- Corner markers -->
            <Grid>
                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="3" WidthRequest="30"
                         HorizontalOptions="Start" VerticalOptions="Start"
                         Margin="4,4,0,0"/>
                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="30" WidthRequest="3"
                         HorizontalOptions="Start" VerticalOptions="Start"
                         Margin="4,4,0,0"/>

                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="3" WidthRequest="30"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,4,4,0"/>
                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="30" WidthRequest="3"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,4,4,0"/>

                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="3" WidthRequest="30"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="4,0,0,4"/>
                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="30" WidthRequest="3"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="4,0,0,4"/>

                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="3" WidthRequest="30"
                         HorizontalOptions="End" VerticalOptions="End"
                         Margin="0,0,4,4"/>
                <BoxView BackgroundColor="{StaticResource Primary}" 
                         HeightRequest="30" WidthRequest="3"
                         HorizontalOptions="End" VerticalOptions="End"
                         Margin="0,0,4,4"/>

                <!-- Animated scan line -->
                <BoxView x:Name="ScanLine"
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="2"
                        VerticalOptions="Start"
                        Margin="8,0"
                        Opacity="0.8"/>
            </Grid>
        </Border>
    </Grid>

</ContentView>
