<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarPlates.Mobile.Controls.EmptyView">

    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
        <Label x:Name="IconLabel" Text="📭" FontSize="64" HorizontalOptions="Center"/>
        <Label x:Name="TitleLabel"
               Text="No Data"
               Style="{StaticResource Title}"
               HorizontalOptions="Center"/>
        <Label x:Name="DescriptionLabel"
               Text="There's nothing to show here yet"
               Style="{StaticResource Body}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"/>
    </VerticalStackLayout>

</ContentView>
