<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarPlates.Mobile.Controls.CameraPreview">

    <Grid BackgroundColor="Black">
        <!-- Platform-specific camera surface will be rendered here -->
        <Grid x:Name="CameraContainer" BackgroundColor="Black"/>

        <!-- Placeholder when camera is not available -->
        <VerticalStackLayout x:Name="PlaceholderView" 
                            IsVisible="False"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
            <Label Text="📷" FontSize="64" HorizontalOptions="Center"/>
            <Label Text="Camera Preview" 
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>

</ContentView>
