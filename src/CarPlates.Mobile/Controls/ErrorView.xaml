<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarPlates.Mobile.Controls.ErrorView">

    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
        <Label Text="⚠️" FontSize="64" HorizontalOptions="Center"/>
        <Label x:Name="ErrorTitle"
               Text="Something went wrong"
               Style="{StaticResource Title}"
               HorizontalOptions="Center"/>
        <Label x:Name="ErrorDescription"
               Text="Please try again later"
               Style="{StaticResource Body}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"/>
        <Button x:Name="RetryButton"
                Text="Retry"
                Style="{StaticResource PrimaryButton}"
                HorizontalOptions="Center"/>
    </VerticalStackLayout>

</ContentView>
