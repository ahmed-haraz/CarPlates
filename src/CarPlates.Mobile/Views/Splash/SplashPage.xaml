<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             x:Class="CarPlates.Mobile.Views.Splash.SplashPage"
             x:DataType="vm:SplashViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Primary}">

    <Grid>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <!-- App Icon -->
            <Frame BackgroundColor="White" 
                   CornerRadius="24" 
                   WidthRequest="120" 
                   HeightRequest="120"
                   Padding="0"
                   HasShadow="True">
                <Label Text="🚗" 
                       FontSize="64" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Frame>

            <!-- App Name -->
            <Label Text="CarPlates" 
                   Style="{StaticResource Headline}"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <!-- Tagline -->
            <Label Text="License Plate Recognition" 
                   Style="{StaticResource Subtitle}"
                   TextColor="{StaticResource PrimaryLight}"
                   HorizontalOptions="Center"/>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="True" 
                               Color="White"
                               Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
