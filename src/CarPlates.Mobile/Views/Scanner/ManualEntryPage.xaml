<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             xmlns:helpers="clr-namespace:CarPlates.Mobile.Helpers"
             x:Class="CarPlates.Mobile.Views.Scanner.ManualEntryPage"
             x:DataType="vm:ManualEntryViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="0">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="16,12"
              ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource Surface}">
            <Image Grid.Column="0"
                   WidthRequest="24"
                   HeightRequest="24"
                   helpers:IconHelper.Glyph="&#xe909;">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ClosePageCommand}" />
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1"
                   Text="{loc:Translate Key=ManualEntry}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="24"
                                 Padding="20,24">

                <!-- Plate Visual Display -->
                <Border Padding="16"
                        BackgroundColor="White"
                        Stroke="{Binding PlateBorderColor}"
                        StrokeThickness="3"
                        StrokeShape="RoundRectangle 12">
                    <Border.Shadow>
                        <Shadow Brush="#22000000" Offset="0,4" Radius="12" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <!-- KSA Badge (right side for RTL) -->
                        <Border Grid.Column="0"
                                BackgroundColor="#1B5E20"
                                Padding="10,8"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="3"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="KSA"
                                       FontSize="11"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold" />
                                <BoxView WidthRequest="24"
                                         HeightRequest="2"
                                         Color="White"
                                         HorizontalOptions="Center" />
                                <Label Text="●"
                                       FontSize="12"
                                       TextColor="White"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Character Slots -->
                        <HorizontalStackLayout Grid.Column="1"
                                                Spacing="6"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center">
                            <!-- Empty state -->
                            <Label Text="{loc:Translate Key=EnterPlateNumberPrompt}"
                                   FontSize="14"
                                   TextColor="#999999"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding PlateText, Converter={StaticResource IsStringEmptyConverter}}" />

                            <!-- Character frames dynamically created from PlateText -->
                            <HorizontalStackLayout Spacing="6"
                                                    BindableLayout.ItemsSource="{Binding PlateChars}"
                                                    IsVisible="{Binding PlateText, Converter={StaticResource IsStringNotEmptyConverter}}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Stroke="#555555"
                                                StrokeThickness="1.5"
                                                Padding="8,6"
                                                MinimumWidthRequest="40"
                                                MinimumHeightRequest="50"
                                                BackgroundColor="#FAFAFA"
                                                StrokeShape="RoundRectangle 4">
                                            <Label Text="{Binding .}"
                                                   FontSize="28"
                                                   FontAttributes="Bold"
                                                   TextColor="{Binding Source={RelativeSource AncestorType={x:Type vm:ManualEntryViewModel}}, Path=PlateTextColor}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- Plate Type Selector -->
                <Label Text="{loc:Translate Key=PlateType}"
                       FontSize="14"
                       FontAttributes="Bold" />
                <FlexLayout Wrap="Wrap"
                            JustifyContent="Start"
                            AlignItems="Start">
                    <BindableLayout.ItemsSource>
                        <Binding Path="PlateTypes" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Padding="12,8"
                                    Margin="4"
                                    Stroke="{DynamicResource Border}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{DynamicResource Surface}">
                                <Border.StyleTriggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type vm:ManualEntryViewModel}}, Path=PlateType}"
                                                 Value="{Binding .}">
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                    </DataTrigger>
                                </Border.StyleTriggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManualEntryViewModel}}, Path=SelectPlateTypeCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding .}"
                                       FontSize="14" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="{loc:Translate Key=Clear}"
                            BackgroundColor="{DynamicResource Surface}"
                            TextColor="{DynamicResource TextPrimary}"
                            BorderColor="{DynamicResource Border}"
                            BorderWidth="1"
                            CornerRadius="12"
                            HeightRequest="48"
                            Command="{Binding ClearPlateCommand}" />
                    <Button Grid.Column="1"
                            Text="{loc:Translate Key=Search}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"
                            Command="{Binding SubmitPlateCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Custom Keypad -->
        <Border Grid.Row="2"
                BackgroundColor="{DynamicResource Surface}"
                Stroke="{DynamicResource Border}"
                StrokeThickness="1"
                Padding="8,12">
            <VerticalStackLayout Spacing="8">
                <!-- Row 1 -->
                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="8">
                    <Button Grid.Column="0" Text="1" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="1" />
                    <Button Grid.Column="1" Text="2" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="2" />
                    <Button Grid.Column="2" Text="3" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="3" />
                    <Button Grid.Column="3" Text="-" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="-" />
                </Grid>
                <!-- Row 2 -->
                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="8">
                    <Button Grid.Column="0" Text="4" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="4" />
                    <Button Grid.Column="1" Text="5" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="5" />
                    <Button Grid.Column="2" Text="6" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="6" />
                    <Button Grid.Column="3" Text="_" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="_" />
                </Grid>
                <!-- Row 3 -->
                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="8">
                    <Button Grid.Column="0" Text="7" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="7" />
                    <Button Grid.Column="1" Text="8" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="8" />
                    <Button Grid.Column="2" Text="9" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="9" />
                    <Button Grid.Column="3" Text="X" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="X" />
                </Grid>
                <!-- Row 4 -->
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Button Grid.Column="0" Text="{loc:Translate Key=Space}" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter=" " />
                    <Button Grid.Column="1" Text="0" Style="{StaticResource KeypadButton}" Command="{Binding KeyPressCommand}" CommandParameter="0" />
                    <Button Grid.Column="2" Text="⌫" Style="{StaticResource KeypadButton}" BackgroundColor="#E53935" TextColor="White" Command="{Binding KeyPressCommand}" CommandParameter="⌫" />
                </Grid>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
