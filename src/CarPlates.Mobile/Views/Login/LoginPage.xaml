<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.Login.LoginPage"
             x:DataType="vm:LoginViewModel"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Background}">
        <Frame Grid.Row="0"
               Style="{StaticResource HeroCard}"
               Margin="20,24,20,0"
               HeightRequest="230">
            <Grid RowDefinitions="*,Auto">
                <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                    <Frame BackgroundColor="{StaticResource AccentSoft}"
                           WidthRequest="76"
                           HeightRequest="76"
                           CornerRadius="24"
                           Padding="0"
                           HasShadow="False"
                           HorizontalOptions="Start">
                        <Label Text="🚘" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                    <Label Text="SMART PLATE ACCESS" Style="{StaticResource Eyebrow}" TextColor="{StaticResource Accent}" />
                    <Label Text="{loc:Translate Key=AppName}"
                           Style="{StaticResource Headline}"
                           TextColor="White" />
                    <Label Text="{loc:Translate Key=SignInToContinue}"
                           Style="{StaticResource Subtitle}"
                           TextColor="#D7E7FF" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,28" Spacing="18">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{loc:Translate Key=WelcomeBack}" Style="{StaticResource Title}" />
                    <Label Text="Securely continue to your vehicle scanning workspace." Style="{StaticResource Subtitle}" />
                </VerticalStackLayout>

                <Frame BackgroundColor="{StaticResource Error}"
                       Padding="14"
                       IsVisible="{Binding HasError}"
                       CornerRadius="18"
                       HasShadow="False">
                    <Label Text="{Binding ErrorMessage}" TextColor="White" FontSize="14" />
                </Frame>

                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{loc:Translate Key=Username}" Style="{StaticResource Eyebrow}" />
                            <Entry Text="{Binding Username}"
                                   Placeholder="{loc:Translate Key=EnterUsername}"
                                   Style="{StaticResource FormEntry}"
                                   ReturnType="Next" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="{loc:Translate Key=Password}" Style="{StaticResource Eyebrow}" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Text="{Binding Password}"
                                       Placeholder="{loc:Translate Key=EnterPassword}"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                                       Style="{StaticResource FormEntry}"
                                       ReturnType="Done" />
                                <Button Grid.Column="1"
                                        Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                                        Style="{StaticResource IconButton}"
                                        Command="{Binding TogglePasswordVisibilityCommand}" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="{loc:Translate Key=SignIn}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
