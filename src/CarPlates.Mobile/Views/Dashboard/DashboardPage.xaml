<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:converters="clr-namespace:CarPlates.Mobile.Converters"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.Dashboard.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:SyncStatusToColorConverter x:Key="SyncStatusToColorConverter"/>
    </ContentPage.Resources>

    <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="18">
                <!-- Welcome Header -->
                <Frame Style="{StaticResource HeroCard}">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                            <Label Text="LIVE CONTROL CENTER" Style="{StaticResource Eyebrow}" TextColor="{StaticResource Accent}" />
                            <Label Text="{Binding UserName}" Style="{StaticResource Headline}" TextColor="White" />
                            <Label Text="{loc:Translate Key=WelcomeBackComma}" Style="{StaticResource Subtitle}" TextColor="#D7E7FF" />
                        </VerticalStackLayout>
                        <Button Grid.Row="0" Grid.Column="1"
                                Text="👤"
                                Style="{StaticResource IconButton}"
                                Command="{Binding NavigateToProfileCommand}" />
                        <Button Grid.Row="2" Grid.ColumnSpan="2"
                                Text="{loc:Translate Key=ScanLicensePlateButton}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding NavigateToScanCommand}"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="{StaticResource PrimaryDark}"
                                HeightRequest="62"
                                FontSize="18" />
                    </Grid>
                </Frame>

                <!-- Statistics Cards -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame Style="{StaticResource ElevatedCard}" Grid.Column="0">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="{Binding Statistics.TodayScans}"
                                   Style="{StaticResource Headline}"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Key=TodaysScans}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Style="{StaticResource ElevatedCard}" Grid.Column="1">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="{Binding Statistics.TotalScans}"
                                   Style="{StaticResource Headline}"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Key=TotalScansLabel}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Frame Style="{StaticResource ElevatedCard}" Grid.Column="0">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="{Binding Statistics.PendingSync}"
                                   Style="{StaticResource Headline}"
                                   TextColor="{StaticResource Warning}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Key=PendingSync}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Style="{StaticResource ElevatedCard}" Grid.Column="1">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="{Binding Statistics.UniqueVehicles}"
                                   Style="{StaticResource Headline}"
                                   TextColor="{StaticResource Success}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Key=UniqueVehicles}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Recent Scans -->
                <Label Text="{loc:Translate Key=RecentScans}" Style="{StaticResource Title}" Margin="0,8,0,0"/>

                <CollectionView ItemsSource="{Binding RecentScans}"
                               EmptyView="{loc:Translate Key=NoRecentScans}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentScanDto">
                            <Frame Style="{StaticResource Card}" Margin="0,6">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Label Grid.Column="0"
                                           Text="🚘"
                                           FontSize="26"
                                           VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Padding="12,0">
                                        <Label Text="{Binding PlateNumber}"
                                               Style="{StaticResource Body}"
                                               FontAttributes="Bold"/>
                                        <Label Text="{Binding VehicleBrand}"
                                               Style="{StaticResource Caption}"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                                        <Label Text="{Binding AccessStatus}"
                                               TextColor="{StaticResource Success}"
                                               FontSize="12"/>
                                        <Label Text="{Binding ScanTime, StringFormat='{0:HH:mm}'}"
                                               Style="{StaticResource Caption}"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ViewVehicleDetailsCommand}"
                                                         CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- View All History -->
                <Button Text="{loc:Translate Key=ViewAllHistory}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding NavigateToHistoryCommand}"/>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
