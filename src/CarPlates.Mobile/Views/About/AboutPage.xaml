<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.About.AboutPage"
             Title="{loc:Translate Key=About}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" HorizontalOptions="Center">
            <!-- App Icon -->
            <Border WidthRequest="120" 
                   HeightRequest="120" 
                   StrokeShape="RoundRectangle 24"
                   BackgroundColor="{StaticResource Primary}"
                   Padding="0">
                <Label Text="🚗" 
                       FontSize="64" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="{loc:Translate Key=AppName}" 
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Center"/>

            <Label Text="{loc:Translate Key=Tagline}" 
                   Style="{StaticResource Subtitle}"
                   HorizontalOptions="Center"/>

            <Label Text="{loc:Translate Key=VersionLabel}" 
                   Style="{StaticResource Caption}"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="{DynamicResource Border}" Margin="0,16"/>

            <Label Text="{loc:Translate Key=BuiltWithDescription}"
                   Style="{StaticResource Body}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <Label Text="{loc:Translate Key=FeaturesLabel}"
                   Style="{StaticResource Body}"
                   FontAttributes="Bold"
                   Margin="0,8,0,0"/>

            <VerticalStackLayout Spacing="4" Padding="16,0">
                <Label Text="{loc:Translate Key=FeatureJwtAuth}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureCameraPreview}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureAutoRecognition}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureEgyptEnglishPlates}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureVehicleLookup}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureOfflineSync}" Style="{StaticResource Caption}"/>
                <Label Text="{loc:Translate Key=FeatureHistoryExport}" Style="{StaticResource Caption}"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{DynamicResource Border}" Margin="0,16"/>

            <Label Text="{loc:Translate Key=Copyright}"
                   Style="{StaticResource Caption}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
