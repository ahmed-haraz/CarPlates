<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarPlates.Mobile.Views.About.AboutPage"
             Title="About">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" HorizontalOptions="Center">
            <!-- App Icon -->
            <Frame WidthRequest="120" 
                   HeightRequest="120" 
                   CornerRadius="24"
                   BackgroundColor="{StaticResource Primary}"
                   Padding="0">
                <Label Text="🚗" 
                       FontSize="64" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

            <Label Text="CarPlates" 
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Center"/>

            <Label Text="License Plate Recognition" 
                   Style="{StaticResource Subtitle}"
                   HorizontalOptions="Center"/>

            <Label Text="Version 1.0.0" 
                   Style="{StaticResource Caption}"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,16"/>

            <Label Text="Built with .NET MAUI, Clean Architecture, and Google ML Kit OCR."
                   Style="{StaticResource Body}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <Label Text="Features:"
                   Style="{StaticResource Body}"
                   FontAttributes="Bold"
                   Margin="0,8,0,0"/>

            <VerticalStackLayout Spacing="4" Padding="16,0">
                <Label Text="• JWT Authentication" Style="{StaticResource Caption}"/>
                <Label Text="• CameraX Live Preview" Style="{StaticResource Caption}"/>
                <Label Text="• Automatic Plate Recognition" Style="{StaticResource Caption}"/>
                <Label Text="• Egyptian & English Plates" Style="{StaticResource Caption}"/>
                <Label Text="• Vehicle Lookup via REST API" Style="{StaticResource Caption}"/>
                <Label Text="• Offline Cache & Sync" Style="{StaticResource Caption}"/>
                <Label Text="• Scan History & Export" Style="{StaticResource Caption}"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,16"/>

            <Label Text="© 2026 CarPlates. All rights reserved."
                   Style="{StaticResource Caption}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
