<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:models="clr-namespace:CarPlates.Domain.Entities;assembly=CarPlates.Domain"
             xmlns:helpers="clr-namespace:CarPlates.Mobile.Helpers"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             xmlns:newOrder="clr-namespace:CarPlates.Mobile.Views.Actions.NewOrder"
             NavigationPage.HasNavigationBar="False"
             x:Class="CarPlates.Mobile.Views.Actions.NewOrderPage"
             x:DataType="vm:NewOrderViewModel">

    <Grid RowDefinitions="Auto,*"
          Padding="0"
          BackgroundColor="{DynamicResource Background}">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,18"
              ColumnDefinitions="Auto,*"
              BackgroundColor="{DynamicResource Surface}">

            <Image Grid.Column="0"
                   WidthRequest="24"
                   HeightRequest="24"
                   helpers:IconHelper.Glyph="&#xe909;">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Image.GestureRecognizers>
            </Image>

            <Label Grid.Column="1"
                   Text="{Binding Title}"
                   Style="{StaticResource Title}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

        </Grid>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1">

            <VerticalStackLayout Spacing="16"
                                 Padding="20,18,20,96">

                <!-- Add Customer Section -->
                <Border Style="{StaticResource Card}"
                        Padding="16">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Image Grid.Column="0"
                               WidthRequest="40"
                               HeightRequest="40"
                               helpers:IconHelper.Glyph="&#xeafc;">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowCustomerPopupCommand}" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label Grid.Column="1"
                               Text="{loc:Translate Key=AddCustomer}"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Customer Info Display -->
                <Border Style="{StaticResource Card}"
                        Padding="16"
                        IsVisible="{Binding SelectedCustomer, Converter={StaticResource IsNotNullConverter}}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding SelectedCustomer.FirstName, StringFormat='{0} {1}', 
                                      Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}}"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Label Text="{Binding SelectedCustomer.PhoneNumber}"
                               FontSize="14"
                               TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Add Vehicle Section -->
                <Border Style="{StaticResource Card}"
                        Padding="16">

                    <Grid ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="12">

                        <Image Grid.Column="0"
                               helpers:IconHelper.Glyph="&#xe962;"
                               WidthRequest="40"
                               HeightRequest="40"
                               BackgroundColor="Transparent">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowVehiclePopupCommand}" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Border Grid.Column="1"
                                Style="{StaticResource Card}"
                                Padding="12,6">

                            <Label Text="{loc:Translate Key=AddVehicle}"
                                   FontSize="12"
                                   TextColor="{StaticResource Success}" />
                        </Border>
                        <Label Grid.Column="2"
                               Text="{loc:Translate Key=AddVehicle}"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Vehicle Info Display -->
                <Border Style="{StaticResource Card}"
                        Padding="16"
                        IsVisible="{Binding SelectedVehicle, Converter={StaticResource IsNotNullConverter}}">
                    <VerticalStackLayout Spacing="8">
                        <Label FontSize="16"
                               FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding SelectedVehicle.Brand}" />
                                    <Span Text=" " />
                                    <Span Text="{Binding SelectedVehicle.Model}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Text="{Binding SelectedVehicle.PlateNumber}"
                               FontSize="14"
                               TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Add Items Section -->
                <Border Style="{StaticResource Card}"
                        Padding="16">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                Style="{StaticResource Card}"
                                Padding="12,6">

                            <Label Text="{loc:Translate Key=AddItems}"
                                   FontSize="12"
                                   TextColor="{StaticResource Success}" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="{loc:Translate Key=AddItems}"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Cart Items List -->
                <CollectionView ItemsSource="{Binding CartItems}"
                                IsVisible="{Binding CartItems.Count, Converter={StaticResource CountToBoolConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CartItem">
                            <Border Style="{StaticResource Card}"
                                    Padding="12"
                                    Margin="0,4">

                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding ServiceItem.Name}"
                                               FontSize="14"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding ServiceItem.Category}"
                                               FontSize="12"
                                               TextColor="{DynamicResource TextSecondary}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding ServiceItem.TotalPrice, StringFormat='{0:N2} SAR'}"
                                           FontSize="14"
                                           VerticalOptions="Center" />
                                    <Stepper Grid.Column="2"
                                             Value="{Binding Quantity}"
                                             Minimum="1"
                                             Maximum="99"
                                             WidthRequest="80" />
                                    <Label Grid.Column="3"
                                           Text="{Binding Quantity}"
                                           FontSize="14"
                                           WidthRequest="30"
                                           HorizontalTextAlignment="Center" />

                                    <Image Grid.Column="4"
                                           WidthRequest="24"
                                           HeightRequest="24"
                                           helpers:IconHelper.Glyph="&#xe93b;">

                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=RemoveCartItemCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Image.GestureRecognizers>

                                    </Image>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Order Notes -->
                <Border Style="{StaticResource Card}"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">

                        <Label Text="{loc:Translate Key=OrderNotes}"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <Editor Placeholder="{loc:Translate Key=WriteHere}"
                                Text="{Binding OrderNotes}"
                                HeightRequest="120"
                                BackgroundColor="Transparent" />
                        <Label Text="٢٠٠/٠"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}"
                               HorizontalOptions="End" />

                        <HorizontalStackLayout Spacing="12"
                                               HorizontalOptions="End">
                            <Button Text="{loc:Translate Key=Signature}"
                                    ImageSource="signature.png"
                                    BackgroundColor="{DynamicResource Surface}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BorderColor="{DynamicResource Border}"
                                    BorderWidth="1"
                                    CornerRadius="20"
                                    Padding="12,8"
                                    Command="{Binding ShowSignaturePadCommand}" />
                            <Button Text="{loc:Translate Key=AddPhotos}"
                                    ImageSource="camera.png"
                                    BackgroundColor="{DynamicResource Surface}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BorderColor="{DynamicResource Border}"
                                    BorderWidth="1"
                                    CornerRadius="20"
                                    Padding="12,8" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Service Assignment -->
                <Border Style="{StaticResource Card}"
                        Padding="16">

                    <VerticalStackLayout Spacing="12">
                        <Label Text="{loc:Translate Key=AssignService}"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="12">
                            <Button Text="{loc:Translate Key=SelectWorkLocation}"
                                    BackgroundColor="{DynamicResource Surface}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BorderColor="{DynamicResource Border}"
                                    BorderWidth="1"
                                    CornerRadius="20"
                                    Padding="12,8"
                                    Command="{Binding ShowLocationPopupCommand}" />
                            <Button Text="{loc:Translate Key=SelectTechnician}"
                                    BackgroundColor="{DynamicResource Surface}"
                                    TextColor="{DynamicResource TextPrimary}"
                                    BorderColor="{DynamicResource Border}"
                                    BorderWidth="1"
                                    CornerRadius="20"
                                    Padding="12,8"
                                    Command="{Binding ShowTechnicianPopupCommand}" />
                        </HorizontalStackLayout>
                        <CollectionView ItemsSource="{Binding SelectedLocation, Converter={StaticResource ObjectToListConverter}}"
                                        IsVisible="{Binding SelectedLocation, Converter={StaticResource IsNotNullConverter}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkLocation">
                                    <Border Style="{StaticResource Card}"
                                            Padding="8,4">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource Success}"
                                               FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <CollectionView ItemsSource="{Binding SelectedTechnician, Converter={StaticResource ObjectToListConverter}}"
                                        IsVisible="{Binding SelectedTechnician, Converter={StaticResource IsNotNullConverter}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Technician">
                                    <Border Style="{StaticResource Card}"
                                            Padding="8,4">
                                        <Label Text="{Binding Name, StringFormat='Tech: {0}'}"
                                               TextColor="{StaticResource Success}"
                                               FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Signature Preview -->
                <Border Style="{StaticResource Card}"
                        Padding="16"
                        IsVisible="{Binding SignatureData, Converter={StaticResource IsNotNullConverter}}">
                    <Image Source="{Binding SignatureData}"
                           HeightRequest="100"
                           Aspect="AspectFit"
                           HorizontalOptions="End" />
                </Border>

                <!-- Spacer -->
                <BoxView HeightRequest="20"
                         BackgroundColor="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Submit Button -->
        <Button Grid.Row="1"
                Text="{loc:Translate Key=Next}"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                CornerRadius="24"
                HeightRequest="56"
                Margin="16,0,16,16"
                VerticalOptions="End"
                Command="{Binding SubmitOrderCommand}" />

        <!-- Customer Search Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsCustomerPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="24"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="320">
                <VerticalStackLayout Spacing="16">
                    <Label Text="{loc:Translate Key=SearchCustomer}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Border Style="{StaticResource Card}"
                            Padding="8">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0"
                                   Text="+966"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   Margin="8,0" />
                            <Entry Grid.Column="1"
                                   Placeholder="{loc:Translate Key=PhoneNumber}"
                                   Text="{Binding SearchPhoneNumber}"
                                   Keyboard="Telephone" />
                        </Grid>
                    </Border>
                    <Button Text="{loc:Translate Key=Search}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="48"
                            Command="{Binding SearchCustomerCommand}" />

                    <!-- New Customer Form -->
                    <VerticalStackLayout Spacing="12"
                                         IsVisible="{Binding NewCustomerPhone, Converter={StaticResource IsNotNullConverter}}">
                        <Label Text="{loc:Translate Key=NewCustomer}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Entry Placeholder="{loc:Translate Key=FirstName}"
                                   Text="{Binding NewCustomerFirstName}" />
                        </Border>
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Entry Placeholder="{loc:Translate Key=LastName}"
                                   Text="{Binding NewCustomerLastName}" />
                        </Border>
                        <HorizontalStackLayout Spacing="24"
                                               HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="8">
                                <RadioButton Content="{loc:Translate Key=Male}"
                                             IsChecked="{Binding NewCustomerGender, Converter={StaticResource StringToBoolConverter}, ConverterParameter=ذكر}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <RadioButton Content="{loc:Translate Key=Female}"
                                             IsChecked="{Binding NewCustomerGender, Converter={StaticResource StringToBoolConverter}, ConverterParameter=أنثى}" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                        <Button Text="{loc:Translate Key=Save}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SaveNewCustomerCommand}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Vehicle Registration Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsVehiclePopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="360"
                    MaximumHeightRequest="600">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Grid.Column="0"
                                   Text="{loc:Translate Key=VehicleDetails}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource Card}"
                                    Padding="8,4">
                                <Label Text="Karage"
                                       FontSize="12" />
                            </Border>
                            <ImageButton Grid.Column="2"
                                         Source="pencil.png"
                                         WidthRequest="24"
                                         HeightRequest="24" />
                        </Grid>

                        <Label Text="{loc:Translate Key=Plate}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />

                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Entry Placeholder="{loc:Translate Key=PlateNumber}"
                                   Text="{Binding NewPlateNumber}" />
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0"
                                       Text="{loc:Translate Key=VIN17Digits}"
                                       TextColor="{StaticResource Success}"
                                       FontSize="12"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Placeholder="{loc:Translate Key=VIN}"
                                       Text="{Binding NewVin}" />
                            </Grid>
                        </Border>
                        <newOrder:VehicleTypeOptionsView />
                        <newOrder:EngineTypeOptionsView />

                        <!-- Brand: tappable field opening an image-grid popup (a native Picker can't show a logo) -->
                        <Label Text="{loc:Translate Key=Brand}"
                               FontSize="12"
                               TextColor="{StaticResource Success}" />
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowBrandPopupCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Grid.Column="0"
                                       Source="car.svg"
                                       WidthRequest="24"
                                       HeightRequest="24" />
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedBrand}"
                                       Margin="8,0"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- Model: tappable field opening an image-grid popup, scoped to the selected brand -->
                        <Label Text="{loc:Translate Key=Model}"
                               FontSize="12"
                               TextColor="{StaticResource Success}" />
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowModelPopupCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Grid.Column="0"
                                       Source="car.svg"
                                       WidthRequest="24"
                                       HeightRequest="24" />
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedModel}"
                                       Margin="8,0"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry Grid.Column="0"
                                       Placeholder="{loc:Translate Key=Mileage}"
                                       Text="{Binding NewMileage}"
                                       Keyboard="Numeric" />
                                <Label Grid.Column="1"
                                       Text="0"
                                       VerticalOptions="Center"
                                       Margin="8,0" />
                            </Grid>
                        </Border>
                        <Picker Title="{loc:Translate Key=VehicleYear}"
                                ItemsSource="{Binding VehicleYears}"
                                SelectedItem="{Binding SelectedVehicleYear}" />

                        <!-- Color: tappable field showing the actual swatch, opening a color-grid popup -->
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowColorPopupCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*">
                                <BoxView Grid.Column="0"
                                         Color="{Binding SelectedColor.Swatch}"
                                         WidthRequest="22"
                                         HeightRequest="22"
                                         CornerRadius="11" />
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedColor.Name}"
                                       Margin="8,0"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                        
                        <Button Text="{loc:Translate Key=Next}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SaveNewVehicleCommand}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- Service Selection Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsServicePopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="18"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="380"
                    MaximumHeightRequest="700">
                <newOrder:ItemOptionsView />
            </Border>
        </Grid>

        <!-- New Service Form Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding NewServiceItem, Converter={StaticResource IsNotNullConverter}}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="340">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="{loc:Translate Key=CreateNewItem}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <ImageButton Grid.Column="1"
                                         Source="close.png"
                                         WidthRequest="24"
                                         HeightRequest="24"
                                         Command="{Binding CloseServicePopupCommand}" />
                        </Grid>

                        <Label Text="{loc:Translate Key=ItemDetails}"
                               FontSize="14"
                               FontAttributes="Bold" />
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Entry Placeholder="{loc:Translate Key=ProductName}"
                                   Text="{Binding NewServiceName}" />
                        </Border>
                        <Picker Title="{loc:Translate Key=Category}"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding NewServiceCategory}" />
                        <Picker Title="{loc:Translate Key=ItemType}">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>{loc:Translate Key=Product}</x:String>
                                    <x:String>{loc:Translate Key=Service}</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <Label Text="{loc:Translate Key=Pricing}"
                               FontSize="14"
                               FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding NewServiceIsTaxable}" />
                            <Label Text="{loc:Translate Key=OpenItem}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0"
                                       Text="SAR"
                                       TextColor="{StaticResource Success}"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="{loc:Translate Key=Price}"
                                       Text="{Binding NewServicePrice}"
                                       Keyboard="Numeric" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Card}"
                                Padding="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0"
                                       Text="SAR"
                                       TextColor="{StaticResource Success}"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="{loc:Translate Key=Cost}"
                                       Text="{Binding NewServiceCost}"
                                       Keyboard="Numeric" />
                            </Grid>
                        </Border>
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding NewServiceIsTaxable}" />
                            <Label Text="{loc:Translate Key=ApplyTax}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Picker Title="{loc:Translate Key=Tax}"
                                ItemsSource="{Binding TaxTypes}"
                                SelectedItem="{Binding NewServiceTaxType}" />
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0"
                                   Text="{Binding NewServicePrice, StringFormat='{0:N2} SAR'}"
                                   TextColor="{DynamicResource TextSecondary}" />
                            <Label Grid.Column="1"
                                   Text="{loc:Translate Key=PriceBeforeTax}"
                                   HorizontalOptions="End"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0"
                                   Text="{Binding NewServiceTotalPrice, StringFormat='{0:N2} SAR'}"
                                   TextColor="{DynamicResource TextSecondary}" />
                            <Label Grid.Column="1"
                                   Text="{loc:Translate Key=PriceWithTax}"
                                   HorizontalOptions="End"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </Grid>

                        <Button Text="{loc:Translate Key=Save}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SaveNewServiceCommand}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- Location Selection Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsLocationPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300">
                <VerticalStackLayout Spacing="12">
                    <Label Text="لون المركبة"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <SearchBar Placeholder="{loc:Translate Key=SearchLocation}" />
                    <!-- Use Locations (WorkLocation items) instead of Colors (string) -->
                    <CollectionView ItemsSource="{Binding Locations}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkLocation">
                                <Border Style="{StaticResource Card}"
                                        Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectLocationCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="16" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Brand Selection Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsBrandPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300"
                    MaximumHeightRequest="500">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:Translate Key=Brand}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <ScrollView MaximumHeightRequest="400">
                        <CollectionView ItemsSource="{Binding Brands}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Style="{StaticResource Card}"
                                            Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectBrandCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Image Grid.Column="0"
                                                   Source="car.svg"
                                                   WidthRequest="28"
                                                   HeightRequest="28" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding .}"
                                                   Margin="10,0"
                                                   FontSize="16"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Model Selection Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsModelPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300"
                    MaximumHeightRequest="500">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:Translate Key=Model}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <ScrollView MaximumHeightRequest="400">
                        <CollectionView ItemsSource="{Binding AvailableModels}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Style="{StaticResource Card}"
                                            Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectVehicleModelCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Image Grid.Column="0"
                                                   Source="car.svg"
                                                   WidthRequest="28"
                                                   HeightRequest="28" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding .}"
                                                   Margin="10,0"
                                                   FontSize="16"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Color Selection Popup -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsColorPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    WidthRequest="300"
                    MaximumHeightRequest="500">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:Translate Key=Color}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <ScrollView MaximumHeightRequest="400">
                        <CollectionView ItemsSource="{Binding Colors}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ColorOption">
                                    <Border Style="{StaticResource Card}"
                                            Padding="12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectColorOptionCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Ellipse Grid.Column="0"
                                                     Fill="{Binding Swatch}"
                                                     WidthRequest="28"
                                                     HeightRequest="28"
                                                     Stroke="Gray"
                                                     StrokeThickness="1" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Margin="10,0"
                                                   FontSize="16"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Signature Pad -->
        <Grid Grid.Row="1"
              BackgroundColor="{DynamicResource Surface}"
              IsVisible="{Binding IsSignaturePadVisible}">
            <Grid RowDefinitions="Auto,*,Auto">
                <Label Grid.Row="0"
                       Text="{loc:Translate Key=WriteSignature}"
                       FontSize="18"
                       HorizontalOptions="Center"
                       Margin="0,20" />
                <BoxView Grid.Row="1"
                         Color="White" />
                <!-- SignaturePad would go here - using a placeholder -->
                <Editor Grid.Row="1"
                        BackgroundColor="{DynamicResource Surface}"
                        Text="{Binding SignatureData}" />
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      Padding="16">
                    <Button Grid.Column="0"
                            Text="{loc:Translate Key=ClearSignature}"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource TextSecondary}"
                            Command="{Binding ClearSignatureCommand}" />
                    <Button Grid.Column="1"
                            Text="{loc:Translate Key=SaveSignature}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Success}"
                            Command="{Binding SaveSignatureCommand}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
