<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             x:Class="CarPlates.Mobile.Views.Actions.ModelSelectionPage"
             x:DataType="vm:NewOrderViewModel"
             Title="اختر الموديل"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto">
            <ImageButton Grid.Column="0" Source="arrow_right.png" WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1" Text="اختر الموديل" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            <ImageButton Grid.Column="2" Source="arrow_left.png" WidthRequest="24" HeightRequest="24"/>
        </Grid>

        <SearchBar Grid.Row="1" Placeholder="بحث" Margin="16,8" Text="{Binding ModelSearchText}"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding PagedModels}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#E0E0E0" CornerRadius="12" Padding="20" BackgroundColor="{DynamicResource Background}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectModelCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <Label Text="{Binding .}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="16,8">
            <Button Grid.Column="0" Text="‹" Command="{Binding PreviousModelPageCommand}" IsEnabled="{Binding CanGoToPreviousModelPage}" />
            <Label Grid.Column="1" Text="{Binding ModelPage, StringFormat='{0}'}" HorizontalOptions="Center" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="›" Command="{Binding NextModelPageCommand}" IsEnabled="{Binding CanGoToNextModelPage}" />
        </Grid>
    </Grid>
</ContentPage>
