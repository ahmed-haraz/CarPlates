<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.Actions.BrandSelectionPage"
             x:DataType="vm:NewOrderViewModel"
             Title="{loc:Translate Key=BrandSelection}"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto">
            <ImageButton Grid.Column="0" Source="arrow_right.png" WidthRequest="24" HeightRequest="24"/>
            <Label Grid.Column="1" Text="{loc:Translate Key=BrandSelection}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            <ImageButton Grid.Column="2" Source="arrow_left.png" WidthRequest="24" HeightRequest="24"/>
        </Grid>

        <SearchBar Grid.Row="1" Placeholder="{loc:Translate Key=Search}" Margin="16,8" Text="{Binding BrandSearchText}"/>

        <CollectionView Grid.Row="2" ItemsSource="{Binding PagedBrands}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#E0E0E0" CornerRadius="12" Padding="16" BackgroundColor="{DynamicResource Background}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NewOrderViewModel}}, Path=SelectBrandCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="{Binding ., Converter={StaticResource BrandToImageConverter}}" 
                                   WidthRequest="48" HeightRequest="48" Aspect="AspectFit"/>
                            <Label Text="{Binding .}" FontSize="12" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="16,8">
            <Button Grid.Column="0" Text="‹" Command="{Binding PreviousBrandPageCommand}" IsEnabled="{Binding CanGoToPreviousBrandPage}" />
            <Label Grid.Column="1" Text="{Binding BrandPage, StringFormat='{0}'}" HorizontalOptions="Center" VerticalOptions="Center" />
            <Button Grid.Column="2" Text="›" Command="{Binding NextBrandPageCommand}" IsEnabled="{Binding CanGoToNextBrandPage}" />
        </Grid>
    </Grid>
</ContentPage>
