<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:models="clr-namespace:CarPlates.Domain.Entities;assembly=CarPlates.Domain"
x:Class="CarPlates.Mobile.Views.Actions.CarDataPage"
              x:Name="CarDataPageRoot"
              x:DataType="vm:CarDataViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="{DynamicResource Background}" Padding="16,12" ColumnDefinitions="Auto,*,Auto">
            <ImageButton Grid.Column="0"
                         Source="arrow_right.png"
                         WidthRequest="24" HeightRequest="24"
                         Command="{Binding GoBackCommand}"/>
            <Label Grid.Column="1"
                   Text="إضافة سيارة جديدة"
                   FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <ImageButton Grid.Column="2"
                         Source="arrow_left.png"
                         WidthRequest="24" HeightRequest="24"/>
        </Grid>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16">

                <!-- Vehicle Card (already known from the plate lookup) -->
                <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="16" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="المركبة" FontSize="16" FontAttributes="Bold"/>
                        <Frame BackgroundColor="#F8F8F8" BorderColor="#EEEEEE" CornerRadius="12" Padding="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label FontSize="18" FontAttributes="Bold">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="ScannedVehicle.Brand"/>
                                                <Binding Path="ScannedVehicle.Model"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Text="{Binding ScannedVehicle.PlateNumber, Converter={StaticResource ArabicToEnglishPlateConverter}}"
                                           FontSize="14" TextColor="Gray"/>
                                    <Label Text="{Binding ScannedVehicle.PlateType}"
                                           FontSize="12" TextColor="{StaticResource Primary}"/>
                                    <Border Padding="8,4" Stroke="{DynamicResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 4" Margin="0,4,0,0" BackgroundColor="{DynamicResource Surface}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ShowColorPopupCommand}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Ellipse Grid.Column="0" Fill="{Binding SelectedColor.Swatch}" WidthRequest="16" HeightRequest="16" Stroke="Gray" StrokeThickness="1" />
                                            <Label Grid.Column="1" Text="{Binding SelectedColor.Name}" Margin="6,0" FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                                <Frame Grid.Column="1" BackgroundColor="#E0E0E0" CornerRadius="8" Padding="10,6"
                                       VerticalOptions="Center" HasShadow="False">
                                    <Label Text="Karage" FontSize="12" FontAttributes="Bold"/>
                                </Frame>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Add Items Section -->
                <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="16" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame Grid.Column="0" BackgroundColor="#F0F0F0" CornerRadius="20" Padding="12,6">
                            <Label Text="Add Items" FontSize="12" TextColor="Green"/>
                        </Frame>
                        <Label Grid.Column="1"
                               Text="إضافة أصناف"
                               FontSize="18" FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowServicePopupCommand}"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- Cart Items List -->
                <CollectionView ItemsSource="{Binding CartItems}"
                              IsVisible="{Binding CartItems.Count, Converter={StaticResource CountToBoolConverter}}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CartItem">
                            <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="12" Padding="12" Margin="0,4">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding ServiceItem.Name}" FontSize="14" FontAttributes="Bold"/>
                                        <Label Text="{Binding ServiceItem.Category}" FontSize="12" TextColor="Gray"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding ServiceItem.TotalPrice, StringFormat='{0:N2} SAR'}"
                                           FontSize="14" VerticalOptions="Center"/>
                                    <Stepper Grid.Column="2"
                                             Value="{Binding Quantity}"
                                             Minimum="1" Maximum="99"
                                             WidthRequest="80"/>
                                    <Label Grid.Column="3"
                                           Text="{Binding Quantity}"
                                           FontSize="14" WidthRequest="30" HorizontalTextAlignment="Center"/>
                                    <ImageButton Grid.Column="4"
                                                 Source="trash.png"
                                                 WidthRequest="24" HeightRequest="24"
                                                 Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CarDataViewModel}}, Path=RemoveCartItemCommand}"
                                                 CommandParameter="{Binding .}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Order Notes -->
                <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="16" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ملاحظة الطلب" FontSize="16" FontAttributes="Bold"/>
                        <Editor Placeholder="اكتب هنا..."
                                Text="{Binding OrderNotes}"
                                HeightRequest="120"
                                BackgroundColor="Transparent"/>
                        <Label Text="٢٠٠/٠" FontSize="12" TextColor="Gray" HorizontalOptions="End"/>
                        <HorizontalStackLayout Spacing="12" HorizontalOptions="End">
                            <Button Text="التوقيع"
                                    ImageSource="signature.png"
                                    BackgroundColor="{DynamicResource Background}" TextColor="Black"
                                    BorderColor="Gray" BorderWidth="1"
                                    CornerRadius="20" Padding="12,8"
                                    Command="{Binding ShowSignaturePadCommand}"/>
                            <Button Text="إضافة صور"
                                    ImageSource="camera.png"
                                    BackgroundColor="{DynamicResource Background}" TextColor="Black"
                                    BorderColor="Gray" BorderWidth="1"
                                    CornerRadius="20" Padding="12,8"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Service Assignment -->
                <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="16" Padding="16" HasShadow="False">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="تعيين الخدمة" FontSize="16" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="12">
                            <Button Text="+ حدد مكان العمل"
                                    BackgroundColor="{DynamicResource Background}" TextColor="Black"
                                    BorderColor="Gray" BorderWidth="1"
                                    CornerRadius="20" Padding="12,8"
                                    Command="{Binding ShowLocationPopupCommand}"/>
                            <Button Text="+ اختيار الفني"
                                    BackgroundColor="{DynamicResource Background}" TextColor="Black"
                                    BorderColor="Gray" BorderWidth="1"
                                    CornerRadius="20" Padding="12,8"
                                    Command="{Binding ShowTechnicianPopupCommand}"/>
                        </HorizontalStackLayout>
                        <CollectionView ItemsSource="{Binding SelectedLocation, Converter={StaticResource ObjectToListConverter}}"
                                        IsVisible="{Binding SelectedLocation, Converter={StaticResource IsNotNullConverter}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:WorkLocation">
                                    <Frame BackgroundColor="#E8F5E9" CornerRadius="20" Padding="8,4">
                                        <Label Text="{Binding Name}" TextColor="Green" FontSize="12"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <CollectionView ItemsSource="{Binding SelectedTechnician, Converter={StaticResource ObjectToListConverter}}"
                                        IsVisible="{Binding SelectedTechnician, Converter={StaticResource IsNotNullConverter}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Technician">
                                    <Frame BackgroundColor="#E8F5E9" CornerRadius="20" Padding="8,4">
                                        <Label Text="{Binding Name, StringFormat='Tech: {0}'}" TextColor="Green" FontSize="12"/>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Signature Preview -->
                <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="16" Padding="16"
                       IsVisible="{Binding SignatureData, Converter={StaticResource IsNotNullConverter}}">
                    <Image Source="{Binding SignatureData}"
                           HeightRequest="100" Aspect="AspectFit"
                           HorizontalOptions="End"/>
                </Frame>

                <!-- Spacer -->
                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Submit Button -->
        <Button Grid.Row="1"
                Text="التالي"
                BackgroundColor="#4CAF50"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                CornerRadius="24"
                HeightRequest="56"
                Margin="16,0,16,16"
                VerticalOptions="End"
                Command="{Binding SubmitOrderCommand}"/>

        <!-- Service Selection Popup -->
        <Grid Grid.Row="1" BackgroundColor="#80000000"
              IsVisible="{Binding IsServicePopupVisible}">
            <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="24" Padding="16"
                   VerticalOptions="Center" HorizontalOptions="Center"
                   WidthRequest="380" MaximumHeightRequest="700">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <Label Grid.Row="0" Text="اختر الفئة" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>

                    <SearchBar Grid.Row="1"
                               Placeholder="بحث عن صنف"
                               Text="{Binding ServiceSearchText}"
                               SearchCommand="{Binding FilterServicesCommand}"/>

                    <HorizontalStackLayout Grid.Row="2" Spacing="8" Margin="0,8">
                        <Button Text="إنشاء صنف جديد"
                                BackgroundColor="#4CAF50" TextColor="White"
                                CornerRadius="8" Padding="12,4"
                                Command="{Binding ShowNewServiceFormCommand}"/>
                    </HorizontalStackLayout>

                    <CollectionView Grid.Row="3" ItemsSource="{Binding FilteredServices}">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ServiceItem">
                                <Frame BackgroundColor="{DynamicResource Background}" BorderColor="#E0E0E0" CornerRadius="12" Padding="12">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CarDataViewModel}}, Path=AddServiceToCartCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                        <Image Source="{Binding Icon}"
                                               WidthRequest="48" HeightRequest="48"
                                               Aspect="AspectFit"/>
                                        <Label Text="{Binding Name}" FontSize="12" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Frame>
        </Grid>

        <!-- New Service Form Popup -->
        <Grid Grid.Row="1" BackgroundColor="#80000000"
              IsVisible="{Binding NewServiceItem, Converter={StaticResource IsNotNullConverter}}">
            <Frame BackgroundColor="{DynamicResource Background}" CornerRadius="24" Padding="20"
                   VerticalOptions="Center" HorizontalOptions="Center"
                   WidthRequest="340">
                <ScrollView>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="إنشاء صنف جديد" FontSize="18" FontAttributes="Bold"/>
                            <ImageButton Grid.Column="1" Source="close.png" WidthRequest="24" HeightRequest="24"
                                         Command="{Binding CloseServicePopupCommand}"/>
                        </Grid>

                        <Label Text="تفاصيل الصنف" FontSize="14" FontAttributes="Bold"/>
                        <Frame BorderColor="LightGray" CornerRadius="12" Padding="8">
                            <Entry Placeholder="اسم المنتج" Text="{Binding NewServiceName}"/>
                        </Frame>
                        <Picker Title="الفئة" ItemsSource="{Binding Categories}" SelectedItem="{Binding NewServiceCategory}"/>
                        <Picker Title="نوع الصنف">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Product</x:String>
                                    <x:String>Service</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <Label Text="التسعير:" FontSize="14" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding NewServiceIsTaxable}"/>
                            <Label Text="صنف مفتوح" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame BorderColor="LightGray" CornerRadius="12" Padding="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="SAR" TextColor="Green" VerticalOptions="Center" Margin="0,0,8,0"/>
                                <Entry Grid.Column="1" Placeholder="السعر" Text="{Binding NewServicePrice}" Keyboard="Numeric"/>
                            </Grid>
                        </Frame>
                        <Frame BorderColor="Green" CornerRadius="12" Padding="8">
                            <Grid ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="SAR" TextColor="Green" VerticalOptions="Center" Margin="0,0,8,0"/>
                                <Entry Grid.Column="1" Placeholder="التكلفة" Text="{Binding NewServiceCost}" Keyboard="Numeric"/>
                            </Grid>
                        </Frame>
                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding NewServiceIsTaxable}"/>
                            <Label Text="تطبيق الضريبة على هذا المنتج" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Picker Title="الضريبة" ItemsSource="{Binding TaxTypes}" SelectedItem="{Binding NewServiceTaxType}"/>
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0" Text="{Binding NewServicePrice, StringFormat='{0:N2} SAR'}" TextColor="Gray"/>
                            <Label Grid.Column="1" Text="السعر قبل الضريبة" HorizontalOptions="End" TextColor="Gray"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,*">
                            <Label Grid.Column="0" Text="{Binding NewServiceTotalPrice, StringFormat='{0:N2} SAR'}" TextColor="Gray"/>
                            <Label Grid.Column="1" Text="السعر شامل الضريبة" HorizontalOptions="End" TextColor="Gray"/>
                        </Grid>

                        <Button Text="حفظ"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SaveNewServiceCommand}"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>

        <!-- Color Selection Popup -->
        <Grid Grid.Row="1" BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsColorPopupVisible}">
            <Border Style="{StaticResource Card}"
                    Padding="20" VerticalOptions="Center" HorizontalOptions="Center"
                    WidthRequest="300" MaximumHeightRequest="500">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="لون المركبة" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Button Grid.Column="1" Text="✕" WidthRequest="28" HeightRequest="28"
                                BackgroundColor="Transparent" TextColor="{DynamicResource TextPrimary}" Padding="0"
                                Command="{Binding CloseColorPopupCommand}" />
                    </Grid>
                    <SearchBar Placeholder="بحث" Text="{Binding ColorSearchText}" />
                    <CollectionView ItemsSource="{Binding PagedColors}" HeightRequest="360">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ColorOption">
                                <Border Style="{StaticResource Card}" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference CarDataPageRoot}, Path=BindingContext.SelectColorOptionCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Ellipse Grid.Column="0" Fill="{Binding Swatch}" WidthRequest="28" HeightRequest="28" Stroke="Gray" StrokeThickness="1" />
                                        <Label Grid.Column="1" Text="{Binding Name}" Margin="10,0" FontSize="16" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                          IsVisible="{Binding Colors.Count, Converter={StaticResource CountToBoolConverter}}">
                        <Button Grid.Column="0" Text="‹" Command="{Binding PreviousColorPageCommand}" IsEnabled="{Binding CanGoToPreviousColorPage}" />
                        <Label Grid.Column="1" Text="{Binding ColorPage, StringFormat='{0}'}" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Button Grid.Column="2" Text="›" Command="{Binding NextColorPageCommand}" IsEnabled="{Binding CanGoToNextColorPage}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Signature Pad -->
        <Grid Grid.Row="1" BackgroundColor="{DynamicResource Background}"
              IsVisible="{Binding IsSignaturePadVisible}">
            <Grid RowDefinitions="Auto,*,Auto">
                <Label Grid.Row="0" Text="فضلاً، اكتب توقيعك" FontSize="18"
                       HorizontalOptions="Center" Margin="0,20"/>
                <BoxView Grid.Row="1" Color="White"/>
                <Editor Grid.Row="1" BackgroundColor="{DynamicResource Background}" Text="{Binding SignatureData}"/>
                <Grid Grid.Row="2" ColumnDefinitions="*,*" Padding="16">
                    <Button Grid.Column="0" Text="مسح التوقيع"
                            BackgroundColor="Transparent" TextColor="Gray"
                            Command="{Binding ClearSignatureCommand}"/>
                    <Button Grid.Column="1" Text="حفظ التوقيع"
                            BackgroundColor="Transparent" TextColor="Green"
                            Command="{Binding SaveSignatureCommand}"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
