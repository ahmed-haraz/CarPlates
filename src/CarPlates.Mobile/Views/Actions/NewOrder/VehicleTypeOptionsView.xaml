<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:helpers="clr-namespace:CarPlates.Mobile.Helpers"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.Actions.NewOrder.VehicleTypeOptionsView"
             x:DataType="vm:NewOrderViewModel">
    <VerticalStackLayout Spacing="8">
        <Label Text="{loc:Translate Key=VehicleType}" Style="{StaticResource Caption}" />
        <CollectionView ItemsSource="{Binding VehicleTypes}" SelectionMode="Single" SelectedItem="{Binding SelectedVehicleType}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Style="{StaticResource SelectableChip}" Margin="0,2">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Image WidthRequest="20" HeightRequest="20" helpers:IconHelper.Glyph="&#xe962;" />
                            <Label Grid.Column="1" Text="{Binding .}" Style="{StaticResource ChipLabel}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
