<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             xmlns:helpers="clr-namespace:CarPlates.Mobile.Helpers"
             x:Class="CarPlates.Mobile.Views.Actions.CashierPage"
             x:DataType="vm:CashierViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Background}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
              BackgroundColor="{DynamicResource Surface}">
            <Label Grid.Column="1"
                   Text="{loc:Translate Key=Cashier}"
                   FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Search Bar -->
        <SearchBar Grid.Row="1"
                   Placeholder="{loc:Translate Key=SearchByPlate}"
                   Text="{Binding SearchText}"
                   Margin="16,8" />

        <!-- Date Filters + Pagination -->
        <Grid Grid.Row="2" Padding="16,0" ColumnDefinitions="*,*,58,58" ColumnSpacing="8">
            <DatePicker Grid.Column="0" Date="{Binding DateFrom}" FontSize="13" />
            <DatePicker Grid.Column="1" Date="{Binding DateTo}" FontSize="13" />
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0" WidthRequest="48" HeightRequest="48"
                    IsEnabled="{Binding CanGoToPreviousPage}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PreviousPageCommand}" />
                </Border.GestureRecognizers>
                <Grid HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="22" HeightRequest="22"
                           helpers:IconHelper.Glyph="&#xe909;"
                           helpers:IconHelper.LightColorResourceKey="IconLight"
                           helpers:IconHelper.DarkColorResourceKey="IconDark" />
                </Grid>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="0" WidthRequest="48" HeightRequest="48"
                    IsEnabled="{Binding CanGoToNextPage}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NextPageCommand}" />
                </Border.GestureRecognizers>
                <Grid HorizontalOptions="Center" VerticalOptions="Center">
                    <Image WidthRequest="22" HeightRequest="22"
                           helpers:IconHelper.Glyph="&#xe90a;"
                           helpers:IconHelper.LightColorResourceKey="IconLight"
                           helpers:IconHelper.DarkColorResourceKey="IconDark" />
                </Grid>
            </Border>
        </Grid>

        <!-- Bills List -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Bills}"
                        Margin="16,8"
                        EmptyView="{loc:Translate Key=NoBillsFound}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:Object">
                    <Border Style="{StaticResource Card}" Margin="0,4" Padding="16">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <!-- Bill Number + Date -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   FontSize="16" FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="Bill #{0} — {1}">
                                        <Binding Path="HeaderId" />
                                        <Binding Path="TransDate" StringFormat="{}{0:D8}" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Grid.Row="0" Grid.Column="1"
                                   FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}">
                                <Label.Text>
                                    <Binding Path="NetTotal" StringFormat="{}{0:N2} SAR" />
                                </Label.Text>
                            </Label>

                            <!-- Plate Number (ReferenceNo) + Customer -->
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="13" TextColor="{DynamicResource TextSecondary}">
                                <Label.Text>
                                    <MultiBinding StringFormat="Plate: {0} | Customer: {1}">
                                        <Binding Path="ReferenceNo" />
                                        <Binding Path="CustomerName" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>

                            <!-- Paid / Balance -->
                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="12" TextColor="{DynamicResource TextSecondary}">
                                <Label.Text>
                                    <MultiBinding StringFormat="Paid: {0:N2} | Balance: {1:N2}">
                                        <Binding Path="Paid" />
                                        <Binding Path="Balance" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Page indicator -->
        <Label Grid.Row="4"
               HorizontalOptions="Center"
               FontSize="12" TextColor="{DynamicResource TextSecondary}"
               Text="{Binding CurrentPage, StringFormat='Page {0}'}" />

        <!-- Loading overlay -->
        <Border Grid.Row="3"
                BackgroundColor="#80FFFFFF"
                IsVisible="{Binding IsBusy}"
                HorizontalOptions="Fill" VerticalOptions="Fill">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Color="{StaticResource Primary}" />
        </Border>

    </Grid>
</ContentPage>
