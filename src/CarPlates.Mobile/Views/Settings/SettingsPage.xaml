<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CarPlates.Mobile.ViewModels"
             xmlns:loc="clr-namespace:CarPlates.Mobile.Localization"
             x:Class="CarPlates.Mobile.Views.Settings.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <!-- Appearance Section -->
            <Label Text="{loc:Translate Key=Appearance}" Style="{StaticResource Title}"/>
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{loc:Translate Key=DarkMode}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{loc:Translate Key=Language}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                        <Picker Grid.Column="1" 
                                ItemsSource="{Binding AvailableLanguages}"
                                SelectedItem="{Binding SelectedLanguage}"
                                WidthRequest="120"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Scanner Section -->
            <Label Text="{loc:Translate Key=Scanner}" Style="{StaticResource Title}" Margin="0,8,0,0"/>
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{loc:Translate Key=OcrConfidence}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding OcrConfidence, StringFormat='{0:P0}'}" Style="{StaticResource Caption}"/>
                    </Grid>
                    <Slider Minimum="0.5" Maximum="1.0" Value="{Binding OcrConfidence}" Margin="0,-8,0,0"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{loc:Translate Key=AutoResumeScanning}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding AutoResume}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- API Section -->
            <Label Text="{loc:Translate Key=ApiConfiguration}" Style="{StaticResource Title}" Margin="0,8,0,0"/>
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{loc:Translate Key=ApiUrl}" Style="{StaticResource Body}" FontAttributes="Bold"/>
                    <Entry Text="{Binding ApiUrl}" Placeholder="https://api.example.com"/>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{loc:Translate Key=PendingSync}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding PendingSyncCount}" Style="{StaticResource Caption}"/>
                    </Grid>
                    <Button Text="{loc:Translate Key=SyncNowButton}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SyncNowCommand}"
                            HeightRequest="44"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Notifications Section -->
            <Label Text="{loc:Translate Key=Notifications}" Style="{StaticResource Title}" Margin="0,8,0,0"/>
            <Frame Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{loc:Translate Key=EnableNotifications}" Style="{StaticResource Body}" VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="{Binding NotificationsEnabled}"/>
                </Grid>
            </Frame>

            <!-- Data Management -->
            <Label Text="{loc:Translate Key=DataManagement}" Style="{StaticResource Title}" Margin="0,8,0,0"/>
            <Frame Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Button Text="{loc:Translate Key=ClearCacheButton}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ClearCacheCommand}"
                            HeightRequest="44"/>
                    <Button Text="{loc:Translate Key=ViewLogsButton}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ViewLogsCommand}"
                            HeightRequest="44"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Save Button -->
            <Button Text="{loc:Translate Key=SaveSettingsButton}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveSettingsCommand}"
                    HeightRequest="56"
                    Margin="0,16,0,0"/>

            <!-- About & Logout -->
            <VerticalStackLayout Spacing="8" Margin="0,16,0,0">
                <Button Text="{loc:Translate Key=AboutButton}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding NavigateToAboutCommand}"
                        HeightRequest="44"/>
                <Button Text="{loc:Translate Key=LogoutButton}"
                        BackgroundColor="{StaticResource Error}"
                        TextColor="White"
                        Command="{Binding LogoutCommand}"
                        HeightRequest="44"
                        CornerRadius="12"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
