<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:CarPlates.Mobile"
       xmlns:splash="clr-namespace:CarPlates.Mobile.Views.Splash"
       xmlns:login="clr-namespace:CarPlates.Mobile.Views.Login"
       xmlns:dashboard="clr-namespace:CarPlates.Mobile.Views.Dashboard"
       xmlns:scanner="clr-namespace:CarPlates.Mobile.Views.Scanner"
       xmlns:history="clr-namespace:CarPlates.Mobile.Views.History"
       xmlns:vehicle="clr-namespace:CarPlates.Mobile.Views.Vehicle"
       xmlns:settings="clr-namespace:CarPlates.Mobile.Views.Settings"
       xmlns:profile="clr-namespace:CarPlates.Mobile.Views.Profile"
       x:Class="CarPlates.Mobile.AppShell"
       Shell.FlyoutBehavior="Disabled">

    <!-- Splash Page (no navigation bar) -->
    <ShellContent Route="splash"
                  ContentTemplate="{DataTemplate splash:SplashPage}"
                  Shell.NavBarIsVisible="False" />

    <!-- Login Page -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate login:LoginPage}"
                  Shell.NavBarIsVisible="False" />

    <!-- Main App Tab Bar -->
    <TabBar Route="main">
        <Tab Title=""
             Icon="dashboard.png"
             AutomationProperties.Name="Dashboard">
            <ShellContent Route="dashboard"
                          ContentTemplate="{DataTemplate dashboard:DashboardPage}" />
        </Tab>

        <Tab Title=""
             Icon="camera.png"
             AutomationProperties.Name="Scan">
            <ShellContent Route="scanner"
                          ContentTemplate="{DataTemplate scanner:ScannerPage}" />
        </Tab>

        <Tab Title=""
             Icon="history.png"
             AutomationProperties.Name="History">
            <ShellContent Route="history"
                          ContentTemplate="{DataTemplate history:HistoryPage}" />
        </Tab>

        <Tab Title=""
             Icon="settings.png"
             AutomationProperties.Name="Settings">
            <ShellContent Route="settings"
                          ContentTemplate="{DataTemplate settings:SettingsPage}" />
        </Tab>
    </TabBar>

    <!-- Detail pages (not in tabs) -->
    <ShellContent Route="vehicle"
                  ContentTemplate="{DataTemplate vehicle:VehicleDetailsPage}"
                  Shell.NavBarIsVisible="True" />

    <ShellContent Route="profile"
                  ContentTemplate="{DataTemplate profile:ProfilePage}"
                  Shell.NavBarIsVisible="True" />

</Shell>
