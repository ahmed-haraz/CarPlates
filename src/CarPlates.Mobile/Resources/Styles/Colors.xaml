<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand palette: midnight, electric blue, and cyan for a modern ANPR/security feel. -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#102A56</Color>
    <Color x:Key="PrimaryLight">#60A5FA</Color>
    <Color x:Key="Accent">#22D3EE</Color>
    <Color x:Key="AccentSoft">#E0F7FF</Color>
    <Color x:Key="PrimarySoft">#EAF1FF</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#0EA5E9</Color>

    <!-- Light -->
    <Color x:Key="BackgroundLight">#F6F8FC</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedLight">#EEF4FF</Color>
    <Color x:Key="TextPrimaryLight">#0F172A</Color>
    <Color x:Key="TextSecondaryLight">#64748B</Color>
    <Color x:Key="BorderLight">#DDE7F3</Color>

    <!-- Dark -->
    <Color x:Key="BackgroundDark">#07111F</Color>
    <Color x:Key="SurfaceDark">#0F1B2D</Color>
    <Color x:Key="SurfaceMutedDark">#14243A</Color>
    <Color x:Key="TextPrimaryDark">#F8FAFC</Color>
    <Color x:Key="TextSecondaryDark">#94A3B8</Color>
    <Color x:Key="BorderDark">#24364F</Color>

    <!-- Shared aliases used by styles and views -->
    <Color x:Key="Background">#F6F8FC</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceMuted">#EEF4FF</Color>
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="Border">#DDE7F3</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="IconLight">#1D4ED8</Color>
    <Color x:Key="IconDark">#93C5FD</Color>
    <Color x:Key="Overlay">#9907111F</Color>

</ResourceDictionary>
