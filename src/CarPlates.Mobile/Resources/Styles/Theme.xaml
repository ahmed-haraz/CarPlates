<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Typography -->
    <Style TargetType="Label" x:Key="Eyebrow">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1.4" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="Label" x:Key="Headline">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="Label" x:Key="Title">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="Label" x:Key="Subtitle">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <Style TargetType="Label" x:Key="Body">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style TargetType="Label" x:Key="Caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <!-- Buttons -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="22,0" />
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimarySoft}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="56" />
    </Style>

    <Style TargetType="Button" x:Key="IconButton">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="WidthRequest" Value="48" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Cards -->
    <Style TargetType="Border" x:Key="Card">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="{DynamicResource Border}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style TargetType="Border" x:Key="ElevatedCard">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 26" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style TargetType="Border" x:Key="HeroCard">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 30" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style TargetType="Border" x:Key="Pill">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimarySoft}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Padding" Value="10,6" />
    </Style>

    <!-- Input Fields -->
    <Style TargetType="Entry" x:Key="FormEntry">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style TargetType="Picker" x:Key="FormPicker">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style TargetType="CollectionView" x:Key="DefaultCollectionView">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

</ResourceDictionary>
