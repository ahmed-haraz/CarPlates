<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Default Page Background -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource Background}" />
    </Style>

    <!-- Default NavigationPage -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="BarTextColor" Value="White" />
    </Style>

    <!-- Default TabbedPage (replaces the old Shell TabBar styling) -->
    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="BarTextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource Primary}" />
        <Setter Property="UnselectedTabColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <!-- Default Label -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Default Button -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="18,12" />
    </Style>

    <!-- Default Entry -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Default Editor -->
    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <!-- Default Picker -->
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TitleColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <!-- Default Frame -->
    <Style TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="{DynamicResource Border}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Default ActivityIndicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!-- Default RefreshView -->
    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource Primary}" />
    </Style>

</ResourceDictionary>
