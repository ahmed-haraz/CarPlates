{
  "ConnectionStrings": {
    "DefaultConnection": "${ConnectionStrings__DefaultConnection}"
  },
  // JWT section intentionally left empty here: real values must be supplied
  // via the JWT__Key, JWT__Issuer, JWT__Audience, JWT__ExpiryMinutes and
  // JWT__RefreshTokenExpiryDays environment variables (double underscore is
  // ASP.NET Core's standard separator, so JWT__Key binds to config key
  // "JWT:Key"). This section name must stay "JWT" - both JwtService (signing)
  // and JwtConfiguration (validation) read from it, and env vars only bind
  // here because the names match.
  "JWT": {},
  "LegacyDes": {
    "Key": "${LegacyDes__Key}",
    "Iv": "${LegacyDes__Iv}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}