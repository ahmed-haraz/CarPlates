{
  "ConnectionStrings": {
    "DefaultConnection": "${ConnectionStrings__DefaultConnection}"
  },
  "JwtSettings": {
    "Key": "${JWT__Key}",
    "Issuer": "${JWT__Issuer}",
    "Audience": "${JWT__Audience}",
    "ExpiryMinutes": "${JWT__ExpiryMinutes}",
    "RefreshTokenExpiryDays": "${JWT__RefreshTokenExpiryDays}"
  },
  "LegacyDes": {
    "Key": "${LegacyDes__Key}",
    "Iv": "${LegacyDes__Iv}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}